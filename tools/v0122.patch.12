+          grep -q 'curseddrone/licenses/NOTICE.md' /tmp/pm.txt
+          grep -q 'curseddrone/licenses/ADDITIONAL_TERMS.md' /tmp/pm.txt
           unzip -l dist/cursed-drone-nextui-tg5040-test.zip | tee /tmp/next.txt
           grep -q 'Tools/tg5040/Cursed Drone.pak/launch.sh' /tmp/next.txt
           grep -q 'Tools/tg5040/Cursed Drone.pak/assets/scales/19-edo.scl' /tmp/next.txt
           grep -q 'Tools/tg5040/Cursed Drone.pak/docs/workflow.ru.md' /tmp/next.txt
           grep -q 'Tools/tg5040/Cursed Drone.pak/licenses/Musical-engine-MIT.txt' /tmp/next.txt
+          grep -q 'Tools/tg5040/Cursed Drone.pak/licenses/NOTICE.md' /tmp/next.txt
+          grep -q 'Tools/tg5040/Cursed Drone.pak/licenses/ADDITIONAL_TERMS.md' /tmp/next.txt
